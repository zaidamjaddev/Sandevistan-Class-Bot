# --- USER IDENTITY ---
# This name will be typed into Zoom/Meet if you aren't logged in
STUDENT_NAME=YourName

# --- NOTIFICATIONS ---
# Choose a unique topic name to avoid others triggering your alarm
# Subscribe to this same topic in the ntfy mobile app
NTFY_TOPIC=Your-secret-topic

# --- SYSTEM CONFIGURATION (OPTIONAL) ---
# Only change these if Chrome is installed in a non-standard location
# CHROME_PATH_WIN=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_PATH_LINUX=/usr/bin/google-chrome
# CHROME_PATH_MAC=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome